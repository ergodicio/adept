# Test config for EM wave dispersion relation validation
# Placeholders (<PLACEHOLDER>) are replaced programmatically in the test

units:
  laser_wavelength: <PLACEHOLDER>      # Set to λ_crit computed from n0
  normalizing_temperature: 1000eV
  normalizing_density: <PLACEHOLDER>   # Set to n0
  Z: 1
  Zp: 1

density:
  quasineutrality: true
  species-background:
    noise_seed: 42
    noise_type: none
    noise_val: 0.0
    v0: 0.0
    T0: 1.0
    m: 2.0
    basis: tanh
    baseline: 0.01
    bump_height: 0.99  # Max density = 1.0; wave propagates since ω_driver > ωpe(n0)
    bump_or_trough: bump
    center: 20um
    rise: 3um
    width: 30um

grid:
  dt: 0.001ps  # Will be overridden for EM stability
  tmin: 0.0ps
  tmax: 1.0ps
  nx: 2048
  xmin: 0.0um
  xmax: 40um
  nv: 64
  vmax: 4.0

save:
  fields:
    t:
      nt: 1001  # Need high resolution to resolve wave frequency (ω ≈ 1.25)
  electron:
    main:
      t:
        nt: 11

solver: vlasov-1d

mlflow:
  experiment: test-vlasov1d-em-dispersion
  run: test

drivers:
  ex: {}
  ey:
    '0':
      params:
        intensity: 1e12W/m^2
        wavelength: <PLACEHOLDER>      # Set to 0.8 × λ_crit (subcritical)
      envelope:
        time:
          center: 5ps
          rise: 0.05ps
          width: 9.9ps
        space:
          center: 2.0um
          rise: 1.0um
          width: 3.0um

diagnostics:
  diag-vlasov-dfdt: false
  diag-fp-dfdt: false

terms:
  field: poisson
  edfdv: exponential
  time: leapfrog
  fokker_planck:
    is_on: false
    type: Dougherty
    time:
      baseline: 0.0
      bump_or_trough: bump
      center: 0.0
      rise: 1.0
      slope: 0.0
      bump_height: 0.0
      width: 1.0
    space:
      baseline: 0.0
      bump_or_trough: bump
      center: 0.0
      rise: 1.0
      slope: 0.0
      bump_height: 0.0
      width: 1.0
  krook:
    is_on: false
    time:
      baseline: 0.0
      bump_or_trough: bump
      center: 0.0
      rise: 1.0
      bump_height: 0.0
      width: 1.0
    space:
      baseline: 0.0
      bump_or_trough: bump
      center: 0.0
      rise: 1.0
      bump_height: 0.0
      width: 1.0
